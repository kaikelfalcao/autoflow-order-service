{
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/microservices": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/typeorm": "^11.0.1",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^1.0.3",
    "axios": "^1.15.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "nest-winston": "^1.10.2",
    "newrelic": "^13.19.2",
    "opossum": "^9.0.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28",
    "uuid": "^14.0.0",
    "winston": "^3.19.0",
    "winston-transport": "^4.9.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.2",
    "@cucumber/messages": "^32.3.1",
    "@nestjs/testing": "^11.1.19",
    "@types/amqplib": "^0.10.8",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/newrelic": "^9.14.8",
    "@types/opossum": "^8.1.9",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "jest": "^30.3.0",
    "sonarqube-scanner": "^4.3.6",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "scripts": {
    "start": "ts-node src/main.ts",
    "start:dev": "ts-node src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:bdd": "cucumber-js --require-module ts-node/register --require test/bdd/steps/**/*.ts test/bdd/features/**/*.feature",
    "typeorm": "typeorm-ts-node-commonjs -d src/infrastructure/database/typeorm.datasource.ts",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "migration:show": "npm run typeorm -- migration:show",
    "db:up": "docker compose -f src/infrastructure/config/docker-compose.yml up -d postgres",
    "db:down": "docker compose -f src/infrastructure/config/docker-compose.yml down"
  }
}
