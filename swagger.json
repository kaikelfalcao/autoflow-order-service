          },
          "name": {
            "type": "string",
            "example": "João Silva",
            "minLength": 3
          },
          "email": {
            "type": "string",
            "example": "joao@email.com"
          },
          "phone": {
            "type": "string",
            "example": "(11) 99999-9999"
          }
        },
        "required": [
